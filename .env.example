# Required API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
FISH_API_KEY=your-fish-audio-api-key-here

# Optional: Fish Audio voice model (defaults to JARVIS MCU voice)
# FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# Optional: Your name (JARVIS will address you by name)
# USER_NAME=Tony

# Optional: Specific Apple Calendar accounts to read (comma-separated emails)
# If not set, JARVIS reads ALL calendars from Apple Calendar
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com

# Gmail integration (Sprint 7)
# 1. Go to https://console.cloud.google.com
# 2. Create a project → enable Gmail API
# 3. Configure OAuth consent screen (External; add your Gmail as test user)
# 4. Create OAuth 2.0 credentials → Desktop app → download credentials.json
# 5. Place credentials.json in this folder (same directory as server.py)
# 6. First use opens a browser for OAuth — token.json is saved automatically
# Paths below are the defaults; only set them if you move the files elsewhere:
# GMAIL_CREDENTIALS_PATH=./credentials.json
# GMAIL_TOKEN_PATH=./token.json

# Web Search (Sprint 10)
# Get a free API key at: https://brave.com/search/api/
# Free tier: 2,000 queries/month
BRAVE_SEARCH_API_KEY=
# SEARCH_PROVIDER=brave   # only supported value currently

# Google Calendar integration (Sprint 8)
# Uses the same credentials.json as Gmail — no new download needed.
# 1. Go to https://console.cloud.google.com → your existing JARVIS project
# 2. APIs & Services → Library → search "Google Calendar API" → Enable
# 3. No new OAuth credentials needed — same credentials.json works
# 4. First use opens a browser OAuth flow — token_calendar.json is saved automatically
# Optional: override where the Calendar token is stored:
# GCAL_TOKEN_PATH=./token_calendar.json
# Optional: set your IANA timezone for accurate time windows (defaults to system local):
# USER_TIMEZONE=America/New_York

# Stream Copilot (Sprint 11)
# High-level streaming macros — "go live", "brb", "panic", "wrap up stream".
# All values below are optional; JARVIS will auto-detect scenes by keyword if not set.
#
# OBS scene names (must match exactly what OBS shows in the Scenes panel):
# STREAM_STARTING_SCENE=Starting Soon
# STREAM_GAMEPLAY_SCENE=Gameplay
# STREAM_BRB_SCENE=BRB
# STREAM_ENDING_SCENE=Ending
# STREAM_SAFE_SCENE=Starting Soon     # scene to cut to on panic (defaults to STREAM_STARTING_SCENE)
#
# Behaviour flags (true/false):
# STREAM_AUTO_RECORD=true             # start recording whenever a stream starts
# STREAM_BRB_MUTES_MIC=true          # mute mic automatically when entering BRB mode
# STREAM_PANIC_STOPS_STREAM=false     # true = panic ends stream; false = cuts to safe scene only
#
# Override mic input name (leave blank to auto-detect from OBS special inputs):
# OBS_MIC_INPUT_NAME=

# Spotify Control (Sprint 12)
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app — set Redirect URI to: http://127.0.0.1:8888/callback
# 3. Copy Client ID and Secret below
# Requires Spotify Premium for playback control commands.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# SPOTIFY_TOKEN_PATH=./token_spotify.json

# Budget Assistant (Sprint 13)
# Path to folder containing Juan_Financial_Dashboard.xlsx
BUDGET_FOLDER=/mnt/c/Users/jbsan/OneDrive/Documents/Payoff debts/Payoff debts
