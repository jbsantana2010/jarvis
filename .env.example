# Required API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
FISH_API_KEY=your-fish-audio-api-key-here

# Optional: Fish Audio voice model (defaults to JARVIS MCU voice)
# FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# Optional: Your name (JARVIS will address you by name)
# USER_NAME=Tony

# Optional: Specific Apple Calendar accounts to read (comma-separated emails)
# If not set, JARVIS reads ALL calendars from Apple Calendar
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com

# Gmail integration (Sprint 7)
# 1. Go to https://console.cloud.google.com
# 2. Create a project → enable Gmail API
# 3. Configure OAuth consent screen (External; add your Gmail as test user)
# 4. Create OAuth 2.0 credentials → Desktop app → download credentials.json
# 5. Place credentials.json in this folder (same directory as server.py)
# 6. First use opens a browser for OAuth — token.json is saved automatically
# Paths below are the defaults; only set them if you move the files elsewhere:
# GMAIL_CREDENTIALS_PATH=./credentials.json
# GMAIL_TOKEN_PATH=./token.json

# Google Calendar integration (Sprint 8)
# Uses the same credentials.json as Gmail — no new download needed.
# 1. Go to https://console.cloud.google.com → your existing JARVIS project
# 2. APIs & Services → Library → search "Google Calendar API" → Enable
# 3. No new OAuth credentials needed — same credentials.json works
# 4. First use opens a browser OAuth flow — token_calendar.json is saved automatically
# Optional: override where the Calendar token is stored:
# GCAL_TOKEN_PATH=./token_calendar.json
# Optional: set your IANA timezone for accurate time windows (defaults to system local):
# USER_TIMEZONE=America/New_York
